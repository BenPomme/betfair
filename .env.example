# Betfair credentials
BF_USERNAME=your_betfair_email
BF_PASSWORD=your_betfair_password
BF_APP_KEY=your_app_key
BF_CERTS_PATH=./certs
# API locale: spain (betfair.es), or leave unset for .com
BF_LOCALE=spain

# Trading mode (ALWAYS start with true)
PAPER_TRADING=true

# Paper trading starting balance
INITIAL_BALANCE_EUR=1000.00
PAPER_STATE_PATH=data/state/paper_executor_state.json
PAPER_TRADES_LOG_PATH=data/state/paper_trades.jsonl
# Proportional staking: fraction of balance per arb (0.10 = 10%)
STAKE_FRACTION=0.10

# Commission
MBR=0.05
DISCOUNT_RATE=0.00

# Thresholds
MIN_NET_PROFIT_EUR=0.10
MIN_LIQUIDITY_EUR=50.00
MAX_STAKE_EUR=100.00
DAILY_LOSS_LIMIT_EUR=50.00
PRE_FILTER_THRESHOLD=0.97
STALE_PRICE_SECONDS=2
STALE_PRICE_SECONDS_PREMATCH=4
STALE_PRICE_SECONDS_INPLAY=2

# Market scanning
SCAN_SPORTS=1,2,7522,4
SCAN_COUNTRIES=GB,ES,IE,FR,DE,IT,AU
SCAN_MAX_MARKETS=200
SCAN_MARKET_TYPES=MATCH_ODDS,DRAW_NO_BET,OVER_UNDER_25,BOTH_TEAMS_TO_SCORE
SCAN_MAX_HOURS_AHEAD=12
SCAN_INCLUDE_IN_PLAY=true
SCAN_MIN_INPLAY_MARKETS=20
SCAN_INTERVAL_SECONDS=2.0
MARKET_REFRESH_INTERVAL_SECONDS=180
MARKET_NO_MOVEMENT_SECONDS=900
MARKET_MISSING_RETIRE_CYCLES=120
PRICE_POLL_INTERVAL_SECONDS=1.0
POLLER_BATCH_SIZE=20
POLLER_CONCURRENT_BATCHES=8
POLLER_REQUEST_TIMEOUT_SECONDS=12.0

CROSS_MARKET_ENABLED=true
CROSS_MARKET_MO_DNB_ENABLED=true
CROSS_MARKET_MO_OU25_ENABLED=false
CROSS_MARKET_MO_BTTS_ENABLED=false
CROSS_MARKET_CS_MO_ENABLED=false

# ML scoring and candidate telemetry
ML_SCORING_ENABLED=true
ML_BASE_DECISION_THRESHOLD_EUR=0.08
ML_MIN_FILL_PROB=0.45
ML_STAKE_SIZING_ENABLED=true
ML_STAKE_MIN_MULTIPLIER=0.35
ML_STAKE_MAX_MULTIPLIER=1.25
ML_STAKE_MIN_EUR=2.00
ML_LINEAR_MODEL_PATH=
FILL_MODEL_PATH=
EXECUTION_TTL_SECONDS=4
CANDIDATE_LOG_ENABLED=true
CANDIDATE_LOG_DIR=data/candidates
CLV_ENABLED=true
CLV_LOG_DIR=data/clv

# Value betting (unhedged single-leg from prediction models)
VALUE_BET_ENABLED=true
VALUE_BET_MIN_ENSEMBLE_SIZE=2
VALUE_BET_MIN_EDGE=0.05
VALUE_BET_MAX_BRIER=0.24
VALUE_BET_KELLY_FRACTION=0.25
VALUE_BET_MAX_STAKE_EUR=50.00
VALUE_BET_MIN_STAKE_EUR=2.00

# Parallel prediction paper account (separate fake bankroll)
PREDICTION_ENABLED=true
PREDICTION_MODEL_KINDS=implied_market,residual_logit,pure_logit
PREDICTION_INITIAL_BALANCE_EUR=100000.00
PREDICTION_STAKE_FRACTION=0.05
PREDICTION_MIN_STAKE_EUR=2.00
PREDICTION_MAX_STAKE_EUR=15.00
PREDICTION_MIN_EDGE=0.03
PREDICTION_MIN_LIQUIDITY_EUR=50.00
PREDICTION_MODEL_DIR=data/prediction/models
PREDICTION_STATE_DIR=data/prediction/state
PREDICTION_SAVE_EVERY=25

# Learning architect (meta-controller)
ARCHITECT_ENABLED=true
ARCHITECT_INTERVAL_SECONDS=900
ARCHITECT_MIN_SETTLED_BETS=30
ARCHITECT_MAX_STAKE_STEP=0.01
ARCHITECT_MAX_EDGE_STEP=0.01
ARCHITECT_MIN_STAKE_FRACTION=0.01
ARCHITECT_MAX_STAKE_FRACTION=0.10
ARCHITECT_MIN_EDGE=0.01
ARCHITECT_MAX_EDGE=0.10
ARCHITECT_LLM_ENABLED=true
ARCHITECT_OLLAMA_MODEL=qwen2.5:32b
ARCHITECT_LOG_DIR=data/architect

# Live QA agent (uses local Ollama)
QA_AGENT_ENABLED=true
QA_AGENT_INTERVAL_SECONDS=300
QA_OLLAMA_ENABLED=true
QA_OLLAMA_MODEL=qwen2.5:32b
QA_OLLAMA_TIMEOUT_SECONDS=30.0
QA_OLLAMA_MAX_BACKOFF_SECONDS=900
QA_AGENT_AUTO_APPLY=true
QA_RESTART_ON_DEGRADED_ENABLED=true
QA_DEGRADED_MIN_AGE_SECONDS=60
QA_RESTART_COOLDOWN_SECONDS=900
QA_LOG_DIR=data/qa

# Dashboard Q&A with local Ollama
DASHBOARD_OLLAMA_MODEL=qwen2.5:32b
DASHBOARD_OLLAMA_TIMEOUT_SECONDS=20.0
DASHBOARD_OLLAMA_CONTEXT_EVENTS=50
DASHBOARD_RELOAD=false

# === FUNDING MODULE ===
FUNDING_MODE=paper
FUNDING_KILL_SWITCH=false
FUNDING_MIN_RATE_PER_8H=0.0002
FUNDING_MIN_ANNUALIZED_YIELD=0.10
FUNDING_MAX_POSITION_USD=500.00
FUNDING_MAX_TOTAL_EXPOSURE_USD=2000.00
FUNDING_MAX_OPEN_HEDGES=5
FUNDING_LEVERAGE=2
FUNDING_MAX_LEVERAGE=5
FUNDING_MARGIN_TYPE=ISOLATED
FUNDING_MIN_LIQUIDATION_DISTANCE=0.30
FUNDING_MAX_HOLD_HOURS=168
FUNDING_ENTRY_WINDOW_MINUTES=30
FUNDING_POLL_INTERVAL_SECONDS=60
FUNDING_SYMBOLS_WATCHLIST_SIZE=50
FUNDING_MIN_24H_VOLUME_USD=50000000
FUNDING_STATE_PATH=data/state/funding_positions.json

# --- Data Collectors (Phase 0) ---
COLLECT_LIQUIDATIONS=true
COLLECT_LONG_SHORT=true
COLLECT_DEPTH=true
LONG_SHORT_POLL_SECONDS=300
DEPTH_POLL_SECONDS=60
DEPTH_TOP_N_SYMBOLS=10
FEAR_GREED_POLL_SECONDS=900

# --- Contrarian Directional Trading (Phase 1) ---
CONTRARIAN_ENABLED=true
CONTRARIAN_MIN_FUNDING_RATE=0.0005
CONTRARIAN_MIN_CONFIDENCE=0.65
CONTRARIAN_CAPITAL_PER_TRADE_PCT=0.025
CONTRARIAN_MAX_POSITIONS=3
CONTRARIAN_STOP_LOSS_PCT=0.025
CONTRARIAN_TAKE_PROFIT_RATIO=2.5
CONTRARIAN_MAX_HOLD_HOURS=72
CONTRARIAN_LEVERAGE=2
CONTRARIAN_MODEL=auto
CONTRARIAN_STATE_PATH=data/state/directional_positions.json
CONTRARIAN_SCAN_INTERVAL_SECONDS=30

# --- Volatility Regime Model (Phase 2) ---
REGIME_ENABLED=false
REGIME_MODEL_TYPE=auto
REGIME_UPDATE_INTERVAL_HOURS=8
REGIME_N_STATES=4
REGIME_CRISIS_HALT_TRADING=true
REGIME_MODEL_PATH=data/funding_models/regime

# --- Strategy Orchestrator (autonomous ML lifecycle) ---
ORCHESTRATOR_ENABLED=true
ORCHESTRATOR_INTERVAL_SECONDS=300
ORCHESTRATOR_MIN_DATA_ROWS=500
ORCHESTRATOR_OLLAMA_MODEL=qwen3.5:27b
ORCHESTRATOR_OLLAMA_TIMEOUT_SECONDS=60.0
ORCHESTRATOR_OLLAMA_ENABLED=true
ORCHESTRATOR_MAX_MODEL_AGE_HOURS=168
ORCHESTRATOR_MIN_WIN_RATE=0.40
ORCHESTRATOR_MIN_TRADES_FOR_EVAL=20
ORCHESTRATOR_LOG_DIR=data/funding_agents

# --- Liquidation Cascade Prediction (Phase 3) ---
CASCADE_ENABLED=true
CASCADE_ALERT_THRESHOLD=0.6
CASCADE_ACTION_THRESHOLD=0.8
CASCADE_MAX_DEFENSIVE_POSITION_PCT=0.05
CASCADE_MONITOR_INTERVAL_SECONDS=300
CASCADE_MODEL_PATH=data/funding_models/cascade

# --- Live activation readiness (dashboard signal) ---
LIVE_READY_BETFAIR_MIN_MODEL_POOL=2
LIVE_READY_BETFAIR_MIN_PASSING_MODELS=2
LIVE_READY_BETFAIR_MIN_PASS_RATE=1.0
LIVE_READY_BETFAIR_MIN_AVG_ROI_200_PCT=0.0
LIVE_READY_BETFAIR_MIN_AVG_BRIER_LIFT_200=0.0
LIVE_READY_BETFAIR_MIN_MODEL_WINDOW_SETTLED=200
LIVE_READY_BINANCE_MIN_MODEL_POOL=2
LIVE_READY_BINANCE_MIN_PASSING_MODELS=2
LIVE_READY_BINANCE_MIN_PASS_RATE=1.0
LIVE_READY_BINANCE_MIN_AVG_ROI_200_PCT=0.0
LIVE_READY_BINANCE_MIN_AVG_BRIER_LIFT_200=0.0
LIVE_READY_BINANCE_MIN_MODEL_WINDOW_SETTLED=200
LIVE_READY_BINANCE_MIN_REALIZED_ROI_PCT=0.0
LIVE_READY_REQUIRE_STRICT_ENFORCEMENT=true
LIVE_READY_REQUIRE_FULL_FUNDING_GATE=true

# Binance Production (leave empty for paper trading)
BINANCE_FUTURES_API_KEY=
BINANCE_FUTURES_API_SECRET=
BINANCE_SPOT_API_KEY=
BINANCE_SPOT_API_SECRET=

# Binance Testnet
BINANCE_FUTURES_TESTNET_API_KEY=your_testnet_key
BINANCE_FUTURES_TESTNET_API_SECRET=your_testnet_secret
BINANCE_SPOT_TESTNET_API_KEY=your_testnet_key
BINANCE_SPOT_TESTNET_API_SECRET=your_testnet_secret

# Infrastructure
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://user:pass@localhost/betfair_arb
TELEGRAM_BOT_TOKEN=your_token
TELEGRAM_CHAT_ID=your_chat_id
